generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS (Les listes de choix)
// =============================================

enum Role {
  RESEARCHER
  PROVIDER
}

enum InstrumentType {
  TELESCOPE
  QUANTUM
  SPECTROGRAPH
  RADIO
}

enum InstrumentStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

// =============================================
// MODELS (Les tables)
// =============================================

model User {
  id          String       @id @default(uuid())
  email       String?      @unique
  name        String?
  role        Role         @default(RESEARCHER)
  createdAt   DateTime     @default(now())

  sessions    Session[]
  instruments Instrument[]
}

model Instrument {
  id          String           @id @default(uuid())
  name        String
  type        InstrumentType
  status      InstrumentStatus @default(ONLINE)
  location    String
  price       Float            // Prix affiché sur le site
  rateUnit    String           // "per_min" ou "per_shot"
  specs       Json?            // Flexible: {"aperture": "600mm"} etc.
  
  providerId  String?
  provider    User?            @relation(fields: [providerId], references: [id])

  createdAt   DateTime         @default(now())
  sessions    Session[]
}

model Session {
  id           String        @id @default(uuid())
  userId       String
  instrumentId String

  status       SessionStatus @default(PENDING)
  duration     Int           // Temps ou nombre de tirs réservés
  totalCost    Float         // Coût calculé pour l'affichage

  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id])
  instrument   Instrument    @relation(fields: [instrumentId], references: [id])
}