generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================

enum Role {
  RESEARCHER
  STUDENT
  PROVIDER
  INSTITUTION
  ADMIN
}

enum InstrumentType {
  TELESCOPE
  QUANTUM
  SPECTROGRAPH
  RADIO
  OTHER
}

enum InstrumentStatus {
  ONLINE
  BUSY
  OFFLINE
  MAINTENANCE
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
  EXPIRED
}

enum EscrowType {
  ESCROW
  PAYMENT_CHANNEL
}

// =============================================
// MODELS
// =============================================

model User {
  id           String    @id @default(uuid())
  xrplAddress  String    @unique
  email        String?   @unique
  name         String?
  role         Role      @default(RESEARCHER)
  institution  String?
  createdAt    DateTime  @default(now())

  sessions     Session[]
  instruments  Instrument[]
  notifications Notification[]
}

model Instrument {
  id           String           @id @default(uuid())
  name         String
  type         InstrumentType
  status       InstrumentStatus @default(ONLINE)
  location     String
  country      String           // Requis par ton code
  priceXRP     Float            // Ton code cherche priceXRP
  rateUnit     String           
  specs        Json?            
  
  providerId   String?
  provider     User?            @relation(fields: [providerId], references: [id])

  createdAt    DateTime         @default(now())
  sessions     Session[]
}

model Session {
  id              String        @id @default(uuid())
  userId          String
  instrumentId    String
  
  escrowType      EscrowType    @default(ESCROW) // Requis par ton code
  status          SessionStatus @default(PENDING)
  durationSec     Int           // Ton code cherche durationSec, pas duration
  actualSec       Float?        // Requis par ton code
  xrpSpent        Float?        // Requis par ton code
  totalCost       Float?

  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id])
  instrument      Instrument    @relation(fields: [instrumentId], references: [id])
  claims          PaymentClaim[]
}

model PaymentClaim {
  id            String   @id @default(uuid())
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}